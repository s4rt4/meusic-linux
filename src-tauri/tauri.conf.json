{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "meusic",
  "version": "0.1.0",
  "identifier": "com.sarta.meusic",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "meusic",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "theme": "Dark",
        "backgroundColor": "#0a0a0f"
      },
      {
        "label": "miniplayer",
        "title": "meusic mini",
        "width": 320,
        "height": 300,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "backgroundColor": "#0d0d12"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
